<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="448.0" prefWidth="939.0" style="-fx-background-color:#F5F7FA;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.MasterSupplier">

    <children>

        <Label layoutX="20" layoutY="15" style="-fx-font-size:24px;                       -fx-font-weight:bold;                       -fx-text-fill:#2C3E50;" text="MASTER SUPPLIER" />

        <VBox layoutX="20" layoutY="55" prefWidth="290" spacing="8" style="-fx-background-color:white;                      -fx-padding:15;                      -fx-background-radius:10;                      -fx-border-radius:10;                      -fx-border-color:#D6DBDF;">

            <Label text="ID Supplier" />
            <TextField fx:id="txtIDSupplier" editable="false" />

            <Label text="Nama Supplier" />
            <TextField fx:id="txtNamaSupplier" />

            <Label text="Alamat" />
            <TextField fx:id="txtAlamat" />

            <Label text="No Telepon" />
            <TextField fx:id="txtTelepon" />

            <Label text="Status" />
            <ComboBox fx:id="cmbStatus" />

            <HBox spacing="8">

                <Button fx:id="btnSimpan" onAction="#saveSupplier" prefWidth="90" text="Simpan" />

                <Button fx:id="btnUbah" onAction="#updateSupplier" prefWidth="90" text="Ubah" />

            </HBox>

            <HBox spacing="8">

                <Button fx:id="btnHapus" onAction="#deleteSupplier" prefWidth="90" text="Hapus" />

                <Button fx:id="btnKembali" onAction="#backDashboard" prefWidth="90" text="Kembali" />

            </HBox>

        </VBox>

        <TableView fx:id="tblSupplier" layoutX="330" layoutY="55" prefHeight="364.0" prefWidth="566.0">

            <columns>

                <TableColumn fx:id="colId" prefWidth="80" text="ID" />

                <TableColumn fx:id="colNama" prefWidth="150" text="Nama Supplier" />

                <TableColumn fx:id="colAlamat" prefWidth="150" text="Alamat" />

                <TableColumn fx:id="colTelepon" prefWidth="100" text="Telepon" />

                <TableColumn fx:id="colStatus" prefWidth="90" text="Status" />

            </columns>

        </TableView>

    </children>

</AnchorPane>