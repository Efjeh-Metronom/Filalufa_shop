<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="763.0" prefWidth="981.0" style="-fx-background-color:#F5F7FA;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.MasterUser">

    <children>

        <Label layoutX="20" layoutY="15" style="-fx-font-size:24px;                       -fx-font-weight:bold;                       -fx-text-fill:#2C3E50;" text="MASTER USER" />

        <VBox layoutX="20" layoutY="55" prefWidth="290" spacing="8" style="-fx-background-color:white;                      -fx-padding:15;                      -fx-background-radius:10;                      -fx-border-radius:10;                      -fx-border-color:#D6DBDF;">

            <Label text="ID User" />
            <TextField fx:id="txtIDUser" editable="false" />

            <Label text="Username" />
            <TextField fx:id="txtUsername" />

            <Label text="Password" />
            <PasswordField fx:id="txtPassword" />

            <Label text="Nama User" />
            <TextField fx:id="txtNamaUser" />

            <Label text="No Telepon" />
            <TextField fx:id="txtTelepon" />

            <Label text="Email" />
            <TextField fx:id="txtEmail" />

            <Label text="Status" />
            <ComboBox fx:id="cmbStatus" />

            <Label text="Role" />
            <ComboBox fx:id="cmbRole" />

            <HBox spacing="8">

                <Button fx:id="btnSimpan" onAction="#saveUser" prefWidth="90" text="Simpan" />

                <Button fx:id="btnUbah" onAction="#updateUser" prefWidth="90" text="Ubah" />

            </HBox>

            <HBox spacing="8">

                <Button fx:id="btnHapus" onAction="#deleteUser" prefWidth="90" text="Hapus" />

                <Button fx:id="btnKembali" onAction="#backDashboard" prefWidth="90" text="Kembali" />

            </HBox>

        </VBox>

        <TableView fx:id="tblUser" layoutX="327.0" layoutY="55.0" prefHeight="566.0" prefWidth="648.0">

            <columns>

                <TableColumn fx:id="colId" prefWidth="60" text="ID" />

                <TableColumn fx:id="colUsername" prefWidth="90" text="Username" />

                <TableColumn fx:id="colNama" prefWidth="120" text="Nama User" />

                <TableColumn fx:id="colTelepon" prefWidth="90" text="Telepon" />

                <TableColumn fx:id="colEmail" prefWidth="140" text="Email" />

                <TableColumn fx:id="colStatus" prefWidth="80" text="Status" />

                <TableColumn fx:id="colRole" prefWidth="70" text="Role" />

            </columns>

        </TableView>

    </children>

</AnchorPane>
